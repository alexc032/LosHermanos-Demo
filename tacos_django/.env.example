# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env a Git.

# Django
SECRET_KEY=cambia-esta-clave-por-una-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de datos MySQL
DB_NAME=tacos_clientes_db
DB_USER=root
DB_PASSWORD=cambia-la-contraseña-de-mysql
DB_HOST=localhost
DB_PORT=3306

# CORS — dominio(s) donde vive tu frontend (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
